@model School.Models.VM

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>
<h4>Enrollment</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger">
            </div>

            <div class="form-group">
                <label class="control-label">Student Name</label>
                <select asp-for="StudentId" class="form-control"
                        asp-items="@(new SelectList(Model.Students, "Id", "Name"))">
                    <option value="">-- Select Student --</option>
                </select>
                <span asp-validation-for="StudentId" class="text-danger"></span>
            </div>


            <div class="form-group">
                <label class="control-label">Course Name</label>
                <select asp-for="CourseId" class="form-control"
                        asp-items="@(new SelectList(Model.Courses, "Id", "Title"))">
                    <option value="">-- Select Course --</option>
                </select>
                <span asp-validation-for="CourseId" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index" class="btn btn-secondary btn-sm mt-2">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}