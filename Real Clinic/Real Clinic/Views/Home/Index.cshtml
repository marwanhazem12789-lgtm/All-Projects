@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to Real Clinic</h1>
    <p>Clinic management has become easier now</p>

    <hr />

    <div class="d-flex justify-content-center gap-3">
        @*  Appoiments *@
        <a asp-controller="Appointment" asp-action="Index" class="btn btn-primary btn-lg">
            Appoiments
        </a>

        @*  Doctors *@
        <a asp-controller="Doctor" asp-action="Index" class="btn btn-success btn-lg">
            Doctors
        </a>

        @* Patients  *@
        <a asp-controller="Patient" asp-action="Index" class="btn btn-info btn-lg">
            Patients
        </a>
    </div>
</div>
