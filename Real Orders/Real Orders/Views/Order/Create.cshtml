@model Real_Orders.Models.OrderViewModel

<div class="container mt-4">
    <h2>Create New Order</h2>
    <hr />

    <form asp-action="Create" method="post">
        <div class="form-group mb-4">
            <label class="control-label fw-bold">Select Customer</label>
            <select asp-for="CustomerId" class="form-control"
                    asp-items="@(new SelectList(Model.customers, "Id", "Name"))">
                <option value="">-- Choose Customer --</option>
            </select>
            <span asp-validation-for="CustomerId" class="text-danger"></span>
        </div>

        <h4 class="mt-4">Select Products</h4>
        <table class="table table-hover border">
            <thead class="table-light">
                <tr>
                    <th>Product Name</th>
                    <th>Price</th>
                    <th style="width: 150px;">Order Quantity</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.avvilableproducts.Count; i++)
                {
                    <tr>
                        <td>
                            @Model.avvilableproducts[i].Name
                            <input type="hidden" asp-for="avvilableproducts[i].Id" />
                            <input type="hidden" asp-for="avvilableproducts[i].Name" />
                            <input type="hidden" asp-for="avvilableproducts[i].Price" />
                        </td>
                        <td>@Model.avvilableproducts[i].Price.ToString("C")</td>
                        <td>
                            <input asp-for="avvilableproducts[i].StockQuantity"
                                   type="number" min="0" class="form-control" placeholder="0" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="form-group mt-4">
            <button type="submit" class="btn btn-primary btn-lg w-100">Confirm Order</button>
        </div>
    </form>
</div>