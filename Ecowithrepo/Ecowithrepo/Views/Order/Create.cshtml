@model OrderViewModel

<form asp-action="Create">
    <label>Select Customer:</label>
    <select asp-for="SelectedCustomerId" class="form-control">
        @foreach (var c in Model.Customers)
        {
            <option value="@c.CustomerID">@c.Name</option>
        }
    </select>

    <table class="table">
        @for (int i = 0; i < Model.Products.Count; i++)
        {
            <tr>
                <td>@Model.Products[i].Name</td>
                <td>@Model.Products[i].Price</td>
                <td>
                    <input type="hidden" asp-for="Products[i].ProductId" />
                    <input type="hidden" asp-for="Products[i].Price" />
                    <input type="number" asp-for="Products[i].Quantity" class="form-control" />
                </td>
            </tr>
        }
    </table>
    <button type="submit" class="btn btn-primary">Place Order</button>
</form>